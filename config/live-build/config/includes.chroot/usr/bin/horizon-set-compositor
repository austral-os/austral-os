#!/bin/bash
set -e

COMPOSITOR=$1

if [ "$COMPOSITOR" != "labwc" ] && [ "$COMPOSITOR" != "wayfire" ]; then
    echo "Uso: $0 [labwc|wayfire]"
    exit 1
fi

# 1. Actualizar la configuración global del sistema
mkdir -p /etc/horizon
echo "$COMPOSITOR" > /etc/horizon/compositor.conf

# 2. Actualizar la configuración de greetd (Gestor de Acceso)
if [ -f /etc/greetd/config.toml ]; then
    if [ "$COMPOSITOR" = "wayfire" ]; then
        # Cambiar el greeter para que se inicie sobre Wayfire (delimitando a default_session de forma robusta)
        sed -i '/\[default_session\]/,/^$/ { s|command = ".*"|command = "env WLR_RENDERER_ALLOW_SOFTWARE=1 wayfire -c /etc/horizon/wayfire-greeter.ini"| }' /etc/greetd/config.toml
    else
        # Cambiar el greeter para que se inicie sobre Labwc (delimitando a default_session de forma robusta)
        sed -i '/\[default_session\]/,/^$/ { s|command = ".*"|command = "env WLR_RENDERER_ALLOW_SOFTWARE=1 labwc -s /usr/bin/horizon-greeter"| }' /etc/greetd/config.toml
    fi
fi

# 3. Actualizar la configuración de systemd (Sesión con Inicio Automático)
if [ -f /etc/systemd/system/horizon.service ]; then
    if [ "$COMPOSITOR" = "wayfire" ]; then
        sed -i 's|^ExecStart=.*|ExecStart=/usr/bin/start-horizon-session-wayfire.sh|' /etc/systemd/system/horizon.service
    else
        sed -i 's|^ExecStart=.*|ExecStart=/usr/bin/start-horizon-session-labwc.sh|' /etc/systemd/system/horizon.service
    fi
    # Recargar la configuración de systemd
    systemctl daemon-reload
fi

echo "El compositor de la sesión se cambió correctamente a $COMPOSITOR"
