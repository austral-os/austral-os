# =========================
# live-build artifacts
# =========================
config/live-build/.build/
config/live-build/chroot/
config/live-build/binary/
config/live-build/cache/

# =========================
# generated outputs
# =========================
config/live-build/*.iso
config/live-build/*.img
config/live-build/live-image-*

# =========================
# build metadata
# =========================
config/live-build/*.files
config/live-build/*.packages
config/live-build/*.contents
config/live-build/*.modified_timestamps
config/live-build/chroot.*

# =========================
# generated config (IGNORE TODO)
# =========================
config/live-build/config/*
!config/live-build/config/binary
!config/live-build/config/bootloaders/
!config/live-build/config/bootloaders/**

# =========================
# KEEP only what YOU define
# =========================

# package lists
!config/live-build/config/package-lists/
!config/live-build/config/package-lists/**

# includes (rootfs customization)
!config/live-build/config/includes.chroot/
!config/live-build/config/includes.chroot/**

# hooks
!config/live-build/config/hooks/
!config/live-build/config/hooks/**

# =========================
# generic
# =========================
*.deb
*.log
*.tmp
.DS_Store